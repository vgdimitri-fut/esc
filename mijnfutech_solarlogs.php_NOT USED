function changeDate2EU($datum)
{
	if( strlen($datum) == 10 )
	{
		$tmp = explode("-", $datum);
	}else
	{
		$datum = substr($datum, 0, 10);
		$tmp = explode("-", $datum);
	}

	return $tmp[2] . "-" . $tmp[1] . "-" . $tmp[0];
}

function maakReferte($cus_id, $conn)
{
    if( empty( $conn ) )
    {
        $cus = mysql_fetch_object( mysql_query("SELECT * FROM kal_customers WHERE cus_id = " . $cus_id) );    
    }else
    {
        $cus = mysql_fetch_object( mysql_query("SELECT * FROM kal_customers WHERE cus_id = " . $cus_id, $conn) );
    }
    
    return str_replace("-", "", substr($cus->cus_date_added, 0, 7) ) . $cus->cus_id;
}

